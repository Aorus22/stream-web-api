# TMDB API Key
# Get your free API key from: https://www.themoviedb.org/settings/api
# 1. Create account at https://www.themoviedb.org/signup
# 2. Go to Settings > API
# 3. Request an API key (choose Developer)
# 4. Copy the "API Key (v3 auth)" value below

TMDB_API_KEY=your_api_key_here

# OpenSubtitles Proxy
# Set to true if your server IP is blocked by OpenSubtitles XML-RPC API
# When enabled, subtitle search requests will be forwarded to the proxy URL
IS_PROXY_OPENSUBTITLE=false
PROXY_OPENSUBTITLE_URL=http://your-old-server:6432/api/subtitles/search
